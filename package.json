{
  "name": "oblivinx3x-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Oblivinx3x Workspace — Embedded Document Database Engine",
  "type": "module",
  "workspaces": [
    "packages/oblivinx3x",
    "packages/oblivinx3x-win32-x64-msvc",
    "packages/oblivinx3x-linux-x64-gnu",
    "packages/oblivinx3x-linux-arm64-gnu",
    "packages/oblivinx3x-darwin-x64",
    "packages/oblivinx3x-darwin-arm64"
  ],
  "scripts": {
    "build": "node scripts/detect-platform.js",
    "build:win": "powershell -ExecutionPolicy Bypass -File scripts\\build.ps1",
    "build:win:debug": "powershell -ExecutionPolicy Bypass -File scripts\\build.ps1 -Debug",
    "build:linux": "bash scripts/build.sh",
    "build:linux:debug": "bash scripts/build.sh --debug",
    "build:release": "cargo build --release -p ovn-neon",
    "build:debug": "cargo build -p ovn-neon",
    "test": "node --test tests/integration/engine.test.js",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "test:integration": "node --test tests/integration/",
    "check": "cargo check",
    "lint": "cargo clippy -- -D warnings",
    "fmt": "cargo fmt"
  },
  "keywords": ["database", "embedded", "document", "nosql", "mvcc", "rust"],
  "author": "Natz",
  "license": "MIT"
}
